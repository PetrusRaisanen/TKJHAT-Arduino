PROJECT_NAME           = "Arduino TKJHAT"
PROJECT_BRIEF          = "Arduino library for Pico HAT extension board"
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
INPUT                  = src examples docs 
RECURSIVE              = YES

FILE_PATTERNS          = *.h \
                         *.hpp \
                         *.ino \
                         *.md

USE_MDFILE_AS_MAINPAGE = docs/index.md

EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES

HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_UNDOC_MACROS      = YES

OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
BUILTIN_STL_SUPPORT    = YES

QUIET                  = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES
VERBATIM_HEADERS       = YES

SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_BY_SCOPE_NAME     = YES

GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = YES

EXAMPLE_PATH           = examples
EXAMPLE_RECURSIVE      = YES

EXCLUDE                = src\display\ 
EXCLUDE 	       = src\microphone

ENABLE_PREPROCESSING   = YES
MARKDOWN_SUPPORT       = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES

PREDEFINED             = ARDUINO=10800 \
                         F\\(x\\)=x \
                         PROGMEM= \
                         PGM_P=char* \
                         __FlashStringHelper=char \
                         String=String \
                         boolean=bool \
                         byte=uint8_t

EXPAND_AS_DEFINED      = F
EXTENSION_MAPPING      = ino=C++